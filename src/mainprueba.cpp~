#include <iostream>
using namespace std;

int main() {
    const int largoTabla = 11;   // Preferiblemente un número primo
    const int saltoPrimo = 7;    // Primo menor que largoTabla

    int claves[] = {10, 25, 37, 48, 59, 70, 81, 92};

    cout << "=== Prueba de funciones Hash ===\n\n";

    for (int clave : claves) {
        cout << "Clave: " << clave << endl;
        cout << "  Modulo:          " << modulo(clave, largoTabla) << endl;
        cout << "  Modulo h2:       " << modulo_h2(clave, saltoPrimo) << endl;
        cout << "  Multiplicacion:  " << hashMult(clave, largoTabla) << endl;
        cout << "  Multiplicacion h2: "
             << hashMult_h2(clave, saltoPrimo) << endl;

        cout << "  Double Hash (Modulo):" << endl;
        for (int i = 0; i < 5; i++) {
            cout << "    Intento " << i << ": "
                 << doubleHashModulo(clave, i, largoTabla, saltoPrimo)
                 << endl;
        }

        cout << "  Double Hash (Multiplicacion):" << endl;
        for (int i = 0; i < 5; i++) {
            cout << "    Intento " << i << ": "
                 << doubleHashMult(clave, i, largoTabla, saltoPrimo)
                 << endl;
        }

        cout << "---------------------------------\n";
    }

    return 0;
}
